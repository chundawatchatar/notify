# PostgreSQL stores core application data.
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=notify
POSTGRES_USER=notify
POSTGRES_PASSWORD=notify
# Used by production releases and container migration commands.
DATABASE_URL=postgresql://notify:notify@localhost:15432/notify

# Redis stores rate limits and short-lived operational state.
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_URL=redis://localhost:16379

# Local application ports.
API_PORT=4100
WEB_PORT=3100
MARKETING_PORT=3200

# Browser-facing URLs. Keep these aligned with API_PORT and WEB_PORT.
VITE_API_URL=http://localhost:4100
PUBLIC_WEB_APP_URL=http://localhost:3100

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3100

# Prometheus metrics are open locally. Production requires a non-empty token.
METRICS_ENABLED=true
METRICS_TOKEN=
