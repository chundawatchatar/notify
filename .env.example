# PostgreSQL stores core application data.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=notify
POSTGRES_USER=notify
POSTGRES_PASSWORD=notify
DATABASE_URL=postgresql://notify:notify@localhost:5432/notify

# Redis stores rate limits and short-lived operational state.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
