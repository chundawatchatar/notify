# PostgreSQL stores core application data.
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=notify
POSTGRES_USER=notify
POSTGRES_PASSWORD=notify
# Used by production releases and container migration commands.
DATABASE_URL=postgresql://notify:notify@localhost:15432/notify

# Redis stores rate limits and short-lived operational state.
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_URL=redis://localhost:16379

# Local application ports.
API_PORT=4100
WEB_PORT=3100
MARKETING_PORT=3200

# Browser-facing URLs. Keep these aligned with API_PORT and WEB_PORT.
VITE_API_URL=http://localhost:4100
PUBLIC_WEB_APP_URL=http://localhost:3100
# Used by the API to build email verification and password-reset links.
WEB_APP_URL=http://localhost:3100
# Development email is delivered to Mailpit over SMTP.
DEV_EMAIL_SMTP_HOST=localhost
# This host port is also used by the API SMTP client.
MAILPIT_SMTP_PORT=1025
# View messages at http://localhost:8025 by default.
MAILPIT_UI_PORT=8025

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3100

# Signs short-lived dashboard access JWTs. Use at least 32 random bytes in production.
AUTH_JWT_SECRET=replace-with-at-least-32-random-bytes

# Prometheus metrics are open locally. Production requires a non-empty token.
METRICS_ENABLED=true
METRICS_TOKEN=
