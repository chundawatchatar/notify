{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@notify/api",
  "projectType": "application",
  "sourceRoot": "apps/api/lib",
  "implicitDependencies": ["@notify/domain", "@notify/open-api"],
  "targets": {
    "deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "apps/api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../tools/with-env.sh mix phx.server",
        "cwd": "apps/api"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../tools/with-env.sh mix phx.server",
        "cwd": "apps/api"
      }
    },
    "setup": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../tools/with-env.sh mix setup",
        "cwd": "apps/api"
      }
    },
    "db-reset": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../tools/with-env.sh env MIX_ENV=dev mix db.reset",
        "cwd": "apps/api"
      }
    },
    "openapi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix openapi.spec.json --spec ApiWeb.OpenApi.ApiSpec --pretty=true ../../packages/openapi/openapi.json",
        "cwd": "apps/api"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile",
        "cwd": "apps/api"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "MIX_ENV=prod mix release --overwrite",
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../tools/with-env.sh mix test",
        "cwd": "apps/api"
      }
    },
    "test-setup": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../tools/with-env.sh env MIX_ENV=test mix test.setup",
        "cwd": "apps/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix format --check-formatted",
        "cwd": "apps/api"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix format",
        "cwd": "apps/api"
      }
    }
  }
}
