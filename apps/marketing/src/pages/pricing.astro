---
import "@notify/styles/app.css";
import { notifyLogoUrl } from "@notify/ui";
// biome-ignore lint/correctness/noUnusedImports: Astro renders this component from the template.
import { PricingPage } from "../components/PricingPage";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={notifyLogoUrl} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Compare Notify subscription plans for realtime notification apps, event volume, and delivery operations."
		/>
		<title>Pricing | Notify</title>
	</head>
	<body>
		<PricingPage />
	</body>
</html>
