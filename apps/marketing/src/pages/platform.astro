---
import "@notify/styles/app.css";
// biome-ignore lint/correctness/noUnusedImports: Astro renders this component from the template.
import { PlatformPage } from "../components/PlatformPage";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Explore the Notify platform for notification apps, event ingress, realtime fanout, delivery logs, and subscription-aware usage controls."
		/>
		<title>Platform | Notify</title>
	</head>
	<body>
		<PlatformPage />
	</body>
</html>
